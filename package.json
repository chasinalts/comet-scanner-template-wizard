{
  "name": "comet-scanner-wizard",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "build:prod": "npm run build",
    "test:performance": "node scripts/performance-test.js",
    "analyze-bundle": "vite build --mode analyze",
    "deploy:netlify": "node scripts/deploy-netlify.js",
    "deploy:github": "node scripts/deploy-github-pages.js",
    "netlify:build": "node netlify-build.js",
    "build:trace": "node --trace-warnings $(which npm) run build",
    "dev:trace": "node --trace-warnings $(which npm) run dev",
    "clear-data": "node scripts/clear-user-data.js",
    "erase-all-now": "node scripts/erase-all-data-now.js",
    "reset-instructions": "node scripts/manual-data-reset.js",
    "setup-owner": "node scripts/setup-owner-account.js",
    "netlify:clean-build": "node netlify-node-version.js && node netlify-build.js",
    "appwrite:get-credentials": "node scripts/get-appwrite-credentials.js",
    "appwrite:update-env": "node scripts/update-env.js",
    "appwrite:check-config": "node scripts/check-appwrite-config.js",
    "appwrite:setup": "node scripts/setup-appwrite.js",
    "appwrite:setup-sdk": "node scripts/setup-appwrite-sdk.js",
    "appwrite:create-owner": "node scripts/create-owner-account.js",
    "appwrite:update-owner": "node scripts/update-owner-account.js",
    "appwrite:create-content": "node scripts/create-initial-content.js",
    "appwrite:setup-resources": "node setup-appwrite-resources.js",
    "appwrite:setup-resources-limited": "node setup-appwrite-resources-limited.js",
    "appwrite:update-env-api-key": "node update-env-with-api-key.js",
    "appwrite:ensure-banner-bucket": "node scripts/ensure-banner-bucket.js",
    "prebuild": "npm run appwrite:ensure-banner-bucket"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@monaco-editor/react": "^4.6.0",
    "appwrite": "^17.0.2",
    "framer-motion": "^11.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.2",
    "react-router-dom": "^6.22.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.11.17",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.17",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^26.1.0",
    "node-appwrite": "^11.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^3.1.2"
  }
}
